    <link rel="icon" type="image/png" href="favicon.png" sizes="16x16">
    <link rel="preload" href="PressStart2P.ttf" as="font" type="font/ttf" crossorigin>

    <style>
        @font-face {
            font-family: 'PressStart2P';
            src: url('PressStart2P.ttf') format('truetype');
            /* Пока шрифт не загружен, текст скрыт — без вспышки системным шрифтом. */
            font-display: block;
        }

        /* Текстовый статус в transfer скрыт: единственная плашка загрузки —
           #infobox, в неё же рантайм пишет статусы установки пакетов. */
        #status { display: none; }

        #progress {
            height: 16px;
            width: 320px;
            margin-top: 14px;
            appearance: none;
            -webkit-appearance: none;
            border: 2px solid #3c2800;
            background: #1a1a1a;
        }
        #progress::-webkit-progress-bar { background: #1a1a1a; }
        #progress::-webkit-progress-value { background: #d4af37; }
        #progress::-moz-progress-bar { background: #d4af37; }

        /* Пока грузится пиксельный шрифт, скрипт вешает класс fonts-loading и
           лоадер скрыт — нет вспышки системным шрифтом. Полярность fail-open:
           если скрипт не выполнился, класса нет и лоадер остаётся видимым. */
        html.fonts-loading #transfer, html.fonts-loading #infobox { visibility: hidden; }

        /* Плашка для JS-ошибок: диагностика прямо на экране. */
        #jserror {
            position: fixed;
            left: 50%;
            bottom: 24px;
            transform: translateX(-50%);
            max-width: 90vw;
            background: #300;
            border: 2px solid #f55;
            color: #faa;
            font-family: monospace;
            font-size: 13px;
            padding: 10px 16px;
            white-space: pre-wrap;
            z-index: 2000000;
            display: none;
        }

        /* Блок с заголовком и прогрессбаром скрыт: до открытия меню игрок
           видит только плашку #infobox «Loading ...». */
        #transfer { display: none !important; }

        .loader-title {
            font-family: 'PressStart2P', monospace;
            font-size: 36px;
            color: #d4af37;
            text-shadow: 4px 4px 0 #3c2800;
            margin-bottom: 10px;
        }

        #infobox {
            /* Центр экрана всегда; !important перебивает инлайн-координаты,
               которые выставляет show_infobox() из шаблонного JS. */
            position: fixed !important;
            left: 50% !important;
            top: 50% !important;
            transform: translate(-50%, -50%) !important;
            background: #1a1a1a;
            border: 2px solid #d4af37;
            color: #d4af37;
            font-family: 'PressStart2P', monospace;
            font-size: 14px;
            padding: 16px 28px;
            z-index: 999999;
            /* Всегда одна строка: и «Loading ...», и статусы установки пакетов. */
            white-space: nowrap;
        }
        div.emscripten { text-align: center; }
        div.emscripten_border { border: 1px solid black; }
        div.thick_border { border: 4px solid black; }

        /* the canvas *must not* have any border or padding, or mouse coords will be wrong */
        /* average size of droid screen 470dp x 320dp  */
        canvas.emscripten {
            border: 0px none;
            background-color: transparent;
            width: 100%;
            height: 100%;
            z-index: 5;

            padding: 0;
            margin: 0 auto;

            position: absolute;
            top: 0;
            bottom: 0;
            left: 0;
            right: 0;
        }

        body {
            font-family: arial;
            margin: 0;
            padding: none;
            background-color: #0a0a0a;
        }

        html, body {
            height: 100%;
            overflow: hidden;
            overscroll-behavior: none;
            touch-action: none;
            /* iOS Safari «умно» увеличивает текст (text autosizing) — из-за
               этого Loading-плашка распухала и переносилась на две строки. */
            -webkit-text-size-adjust: 100%;
            text-size-adjust: 100%;
        }

        /* Растягиваем игровой канвас на всё окно без чёрных полос.
           !important перебивает инлайн-стили, которые pygbag выставляет через
           window_resize(); object-fit: fill заполняет весь экран (лёгкое
           растяжение на не-16:10 мониторах); pixelated держит пиксель-арт чётким. */
        #canvas {
            position: fixed !important;
            top: 0 !important;
            left: 0 !important;
            width: 100vw !important;
            height: 100vh !important;
            object-fit: fill !important;
            image-rendering: pixelated !important;
            background-color: #0a0a0a !important;
            /* Тач-жесты (скролл, зум, double-tap) не должны перехватывать игру. */
            touch-action: none !important;
            -webkit-user-select: none;
            user-select: none;
        }

        .topright{
           position:absolute;
           top:0px;
           right:0px;
        }

        .bottomright {
            position:absolute;
            top: 40%;
            right: 0px;
        }

        .center {
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .trinfo{
           position: relative;
           right: 0px;
           border: 1px solid black;
        }

        .framed{
           position: relative;
           top: 150px;
           right: 10px;
           border: 1px solid black;
        }
    </style>

